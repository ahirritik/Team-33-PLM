@model PLM.Models.BoM

@{
    ViewData["Title"] = "Create BoM";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Create New BoM Header</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info small mb-4">
                    <i class="bi-info-circle me-1"></i> Creating a new BoM sets the version to <strong>v1</strong>. You can add components and operations after creation.
                </div>
                
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="ProductId" class="form-label fw-bold">Select Active Product <span class="text-danger">*</span></label>
                        <select asp-for="ProductId" class="form-select" asp-items="ViewBag.Products">
                            <option value="">-- Select Product --</option>
                        </select>
                        <span asp-validation-for="ProductId" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi-check-lg me-1"></i> Create BoM Header</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
