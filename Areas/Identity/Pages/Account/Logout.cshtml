@page
@model LogoutModel

@{
    ViewData["Title"] = "Signed Out";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PLM System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body {
            background: linear-gradient(135deg, #0d1b2a 0%, #1b2838 50%, #2c3e50 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }
        .logout-card {
            background: #fff; border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 48px 50px; text-align: center;
            max-width: 420px; width: 100%;
        }
        .check-icon {
            width: 72px; height: 72px;
            background: linear-gradient(135deg, #28a745, #20c997);
            border-radius: 50%;
            display: inline-flex; align-items: center; justify-content: center;
            margin-bottom: 20px; font-size: 2rem; color: #fff;
        }
    </style>
</head>
<body>
    <div class="logout-card">
        <div class="check-icon"><i class="bi-check-lg"></i></div>
        <h3 class="fw-bold mb-2">You have been signed out</h3>
        <p class="text-muted mb-4">Thank you for using PLM System. Your session has been securely ended.</p>
        <a href="~/Identity/Account/Login" class="btn btn-primary px-4 py-2 rounded-pill fw-bold">
            <i class="bi-box-arrow-in-right me-1"></i> Sign In Again
        </a>
    </div>
</body>
</html>
