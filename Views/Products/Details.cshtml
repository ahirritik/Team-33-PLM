@model PLM.Models.Product

@{
    ViewData["Title"] = "Product Details - " + Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Product Details: @Model.Name</h1>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="bi-arrow-left me-1"></i> Back to List</a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Master Data</h6>
                @if (Model.Status == PLM.Models.ProductStatus.Active)
                {
                    <span class="badge bg-success px-3 py-2">Active</span>
                }
                else
                {
                    <span class="badge bg-dark px-3 py-2">Archived</span>
                }
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Product ID</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Id</dd>

                    <dt class="col-sm-4 text-muted">Product Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4 text-muted">Current Version</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary">@Model.CurrentVersion</span></dd>

                    <dt class="col-sm-4 text-muted">Sale Price</dt>
                    <dd class="col-sm-8">₹ @Model.SalePrice.ToString("N2")</dd>

                    <dt class="col-sm-4 text-muted">Cost Price</dt>
                    <dd class="col-sm-8 text-danger">₹ @Model.CostPrice.ToString("N2")</dd>

                    <dt class="col-sm-4 text-muted">Attachments</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(Model.Attachments))
                        {
                            <a href="@Model.Attachments" target="_blank">View File</a>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 font-weight-bold text-primary">Actions</h6>
            </div>
            <div class="card-body">
                @if (Model.Status == PLM.Models.ProductStatus.Active && !User.IsInRole("Operations User"))
                {
                    <p class="text-muted small">To modify this product, you must raise an Engineering Change Order (ECO).</p>
                    <a asp-controller="ECOs" asp-action="Create" asp-route-productId="@Model.Id" asp-route-type="0" class="btn btn-warning w-100 mb-2"><i class="bi-file-earmark-diff"></i> Raise ECO (Product)</a>
                    <a asp-controller="ECOs" asp-action="Create" asp-route-productId="@Model.Id" asp-route-type="1" class="btn btn-info w-100"><i class="bi-diagram-3"></i> Raise ECO (BoM)</a>
                }
                else if (Model.Status == PLM.Models.ProductStatus.Archived)
                {
                    <div class="alert alert-secondary mb-0">
                        <i class="bi-info-circle me-1"></i> This product is archived and cannot be modified or used in new BoMs/ECOs.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
