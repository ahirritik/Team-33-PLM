@model IEnumerable<PLM.Controllers.ECOViewModel>

@{
    ViewData["Title"] = "Engineering Change Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Engineering Change Orders</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Engineering User"))
    {
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi-plus-lg me-1"></i> New ECO</a>
    }
</div>

<div class="card shadow mb-4 border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Reference</th>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Product</th>
                        <th>Stage</th>
                        <th>Effective Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@item.ReferenceNumber</td>
                            <td>@item.Title</td>
                            <td><span class="badge bg-secondary">@item.Type</span></td>
                            <td>@item.ProductName</td>
                            <td>
                                @if (item.Stage == PLM.Models.ECOStage.New)
                                {
                                    <span class="badge bg-info">Draft</span>
                                }
                                else if (item.Stage == PLM.Models.ECOStage.Approval)
                                {
                                    <span class="badge bg-warning text-dark">In Review</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Applied</span>
                                }
                            </td>
                            <td>@item.EffectiveDate.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Manage</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">No ECOs found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
