@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="nav flex-column mb-sm-auto mb-0 align-items-center align-items-sm-start w-100" id="loginMenu">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item w-100">
        <a class="nav-link text-white px-0 align-middle" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="fs-5 bi-person-circle"></i> <span class="ms-2 d-none d-sm-inline">@User.Identity?.Name</span>
        </a>
    </li>
    <li class="nav-item w-100 mt-2">
        <form class="form-inline w-100" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link text-danger px-0 align-middle text-start w-100">
                <i class="fs-5 bi-box-arrow-right"></i> <span class="ms-2 d-none d-sm-inline">Logout</span>
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item w-100">
        <a class="nav-link text-white px-0 align-middle" asp-area="Identity" asp-page="/Account/Register">
            <i class="fs-5 bi-person-plus"></i> <span class="ms-2 d-none d-sm-inline">Register</span>
        </a>
    </li>
    <li class="nav-item w-100">
        <a class="nav-link text-white px-0 align-middle" asp-area="Identity" asp-page="/Account/Login">
            <i class="fs-5 bi-box-arrow-in-right"></i> <span class="ms-2 d-none d-sm-inline">Login</span>
        </a>
    </li>
}
</ul>
