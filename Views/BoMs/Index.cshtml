@model IEnumerable<PLM.Controllers.BoMViewModel>

@{
    ViewData["Title"] = "Bills of Materials";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Bills of Materials</h1>
    @if (!User.IsInRole("Operations User"))
    {
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi-plus-lg me-1"></i> New BoM</a>
    }
</div>

<div class="card shadow mb-4 border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Product</th>
                        <th>Version</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-bold">@item.ProductName</td>
                            <td><span class="badge bg-secondary">@item.Version</span></td>
                            <td>
                                @if (item.Status == PLM.Models.BoMStatus.Active)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-dark">Archived</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">View Setup</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No Bills of Materials found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
