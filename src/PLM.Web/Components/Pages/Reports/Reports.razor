@page "/reports"
@using Microsoft.AspNetCore.Authorization
@using PLM.Application.DTOs
@using PLM.Application.Interfaces
@inject IAuditService AuditService
@attribute [Authorize(Roles = "Admin,Operations")]

<PageTitle>System Audit Logs - PLM Engineer</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">System Activity & Audit Logs</MudText>

    <MudDataGrid T="AuditLogDto" Items="@_logs" Filterable="true" SortMode="SortMode.Multiple" Groupable="true" 
                 Hover="true" Dense="true" Elevation="2" Class="rounded-lg">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Global Event Stream</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search entity type..." Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" 
                          OnKeyUp="HandleSearch" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Timestamp" Title="Time" Sortable="true" Filterable="true">
                <CellTemplate>
                    @context.Item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Action" Title="Event" Sortable="true" Filterable="true">
                <CellTemplate>
                    <MudChip T="string" Color="@GetActionColor(context.Item.Action)" Size="Size.Small" Variant="Variant.Outlined">
                        @context.Item.Action
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.EntityType" Title="Entity" Sortable="true" Filterable="true" />
            <PropertyColumn Property="x => x.EntityId" Title="ID" Sortable="true" />
            <PropertyColumn Property="x => x.UserName" Title="User" Sortable="true" Filterable="true" />
            <TemplateColumn Title="Changes" Filterable="false" Sortable="false">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.OldValue) || !string.IsNullOrEmpty(context.Item.NewValue))
                    {
                        <div class="d-flex align-center cursor-pointer" @onclick="@(() => ToggleDetails(context.Item.Id))">
                            <MudIcon Icon="@(_expandedRows.Contains(context.Item.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
                            <MudText Typo="Typo.caption" Class="ml-1 text-primary">View Diff</MudText>
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">No data</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent>
            @if (_expandedRows.Contains(context.Item.Id))
            {
                <td colspan="6" class="bg-light pa-4">
                    <MudGrid>
                        <MudItem xs="6">
                            <MudText Typo="Typo.subtitle2" Color="Color.Error" Class="mb-2">Previous State</MudText>
                            <pre class="bg-white pa-2 rounded border" style="max-height: 200px; overflow-y: auto; font-size: 0.8rem;">
                                @(string.IsNullOrEmpty(context.Item.OldValue) ? "null" : context.Item.OldValue)
                            </pre>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.subtitle2" Color="Color.Success" Class="mb-2">New State</MudText>
                            <pre class="bg-white pa-2 rounded border" style="max-height: 200px; overflow-y: auto; font-size: 0.8rem;">
                                @(string.IsNullOrEmpty(context.Item.NewValue) ? "null" : context.Item.NewValue)
                            </pre>
                        </MudItem>
                    </MudGrid>
                </td>
            }
        </ChildRowContent>
        <PagerContent>
            <MudDataGridPager T="AuditLogDto" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<AuditLogDto> _logs = new();
    private string _searchString = "";
    private HashSet<int> _expandedRows = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        var result = await AuditService.GetPagedAsync(1, 200, string.IsNullOrWhiteSpace(_searchString) ? null : _searchString);
        _logs = result.Items.OrderByDescending(l => l.Timestamp).ToList();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadDataAsync();
        }
    }

    private void ToggleDetails(int id)
    {
        if (_expandedRows.Contains(id))
            _expandedRows.Remove(id);
        else
            _expandedRows.Add(id);
    }

    private Color GetActionColor(string action)
    {
        var a = action.ToLower();
        if (a.Contains("create") || a.Contains("add") || a.Contains("approve")) return Color.Success;
        if (a.Contains("delete") || a.Contains("remove") || a.Contains("reject") || a.Contains("archive")) return Color.Error;
        if (a.Contains("update") || a.Contains("modify") || a.Contains("change")) return Color.Warning;
        return Color.Info;
    }
}
