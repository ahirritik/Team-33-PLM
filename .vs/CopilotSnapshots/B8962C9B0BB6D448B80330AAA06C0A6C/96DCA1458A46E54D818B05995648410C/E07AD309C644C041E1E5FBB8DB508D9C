@page "/products/create"
@using Microsoft.AspNetCore.Authorization
@using PLM.Application.DTOs
@using PLM.Application.Interfaces
@using System.Security.Claims
@inject IProductService ProductService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "Engineering,Admin")]

<PageTitle>Create Product - PLM Engineer</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 mb-16">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />
    
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => NavManager.NavigateTo("/products"))" Class="mr-2" />
        <MudText Typo="Typo.h4">Create New Product</MudText>
    </div>

    <EditForm Model="@_model" OnValidSubmit="OnValidSubmit">
        <FluentValidationValidator />
        
        <MudGrid>
            <MudItem xs="12">
                <MudPaper Elevation="3" Class="pa-6 rounded-lg">
                    <MudText Typo="Typo.h6" Class="mb-4">Product Information</MudText>
                    
                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Name" Label="Product Name" Required="true" 
                                          Variant="Variant.Outlined" For="@(() => _model.Name)" MaxLength="255" />
                        </MudItem>
                        
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Description" Label="Description" Lines="3" 
                                          Variant="Variant.Outlined" For="@(() => _model.Description)" />
                        </MudItem>
                        
                        <MudItem xs="12" sm="6">
                            <MudNumericField @bind-Value="_model.CostPrice" Label="Cost Price" 
                                             Variant="Variant.Outlined" Adornment="Adornment.Start" 
                                             AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" 
                                             For="@(() => _model.CostPrice)" />
                        </MudItem>
                        
                        <MudItem xs="12" sm="6">
                            <MudNumericField @bind-Value="_model.SalePrice" Label="Sale Price" 
                                             Variant="Variant.Outlined" Adornment="Adornment.Start" 
                                             AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" 
                                             For="@(() => _model.SalePrice)" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="0" Class="pa-3 rounded border border-dashed">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Attachment</MudText>
                                <input id="productAttachmentUrl" @bind="_model.Attachments" class="d-none" />
                                <input id="productAttachmentName" @bind="_uploadedFileName" class="d-none" />
                                <div class="d-flex align-center gap-2 mt-2">
                                    <input id="productAttachmentInput" type="file" class="d-none" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx,.xls,.xlsx" />
                                    <MudButton HtmlTag="label" for="productAttachmentInput" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile">
                                        Choose File
                                    </MudButton>
                                    <button type="button" class="btn btn-outline-primary"
                                            onclick="plmUpload.uploadAndBind({ fileInputId: 'productAttachmentInput', scope: 'products', urlInputId: 'productAttachmentUrl', nameInputId: 'productAttachmentName', statusElementId: 'productAttachmentStatus' })">
                                        Upload
                                    </button>

                                    @if (!string.IsNullOrWhiteSpace(_model.Attachments))
                                    {
                                        <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">@_uploadedFileName</MudChip>
                                        <MudLink Href="@_model.Attachments" Target="_blank" Underline="Underline.Hover">View</MudLink>
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Small" OnClick="ClearAttachment" />
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" id="productAttachmentStatus">No file selected</MudText>
                                    }
                                </div>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudNumericField Value="1" Label="Version" Variant="Variant.Outlined" ReadOnly="true" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" 
                           OnClick="@(() => NavManager.NavigateTo("/products"))">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" 
                           Color="Color.Primary" Disabled="@_isSubmitting" 
                           StartIcon="@Icons.Material.Filled.Save">
                    @if (_isSubmitting)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Creating...</MudText>
                    }
                    else
                    {
                        <MudText>Create Product</MudText>
                    }
                </MudButton>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>

@code {
    private ProductCreateDto _model = new();
    private bool _isSubmitting = false;
    private string? _uploadedFileName;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override void OnInitialized()
    {
        _breadcrumbs.Add(new BreadcrumbItem("Dashboard", href: "/"));
        _breadcrumbs.Add(new BreadcrumbItem("Products", href: "/products"));
        _breadcrumbs.Add(new BreadcrumbItem("Create", href: null, disabled: true));
    }

    private async Task OnValidSubmit()
    {
        try
        {
            _isSubmitting = true;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "system";
            var userName = user.Identity?.Name ?? "Administrator";

            var result = await ProductService.CreateAsync(_model, userId, userName);
            Snackbar.Add("Product created successfully (Direct Entry)", Severity.Success);
            
            NavManager.NavigateTo($"/products/{result.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating product: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void ClearAttachment()
    {
        _model.Attachments = null;
        _uploadedFileName = null;
    }
}
