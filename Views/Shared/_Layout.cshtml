@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PLM</title>
    
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PLM.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <div class="col-auto col-md-3 col-xl-2 px-sm-2 px-0 bg-dark">
                <div class="d-flex flex-column align-items-center align-items-sm-start px-3 pt-2 text-white min-vh-100">
                    <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center pb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                        <span class="fs-5 d-none d-sm-inline fw-bold text-uppercase mt-2"><i class="bi-box-seam me-2"></i>PLM System</span>
                    </a>
                    <ul class="nav nav-pills flex-column mb-sm-auto mb-0 align-items-center align-items-sm-start w-100 mt-3" id="menu">
                        <li class="nav-item w-100">
                            <a asp-controller="Home" asp-action="Index" class="nav-link text-white px-0 align-middle">
                                <i class="fs-5 bi-speedometer2"></i> <span class="ms-2 d-none d-sm-inline">Dashboard</span>
                            </a>
                        </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item w-100 mt-2">
                                <span class="text-secondary small fw-bold text-uppercase d-none d-sm-inline">Master Data</span>
                            </li>
                            @if (!User.IsInRole("Operations User"))
                            {
                                <li class="nav-item w-100">
                                    <a asp-controller="Products" asp-action="Index" class="nav-link text-white px-0 align-middle">
                                        <i class="fs-5 bi-tags"></i> <span class="ms-2 d-none d-sm-inline">Products</span>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item w-100">
                                    <a asp-controller="Products" asp-action="Index" class="nav-link text-white px-0 align-middle">
                                        <i class="fs-5 bi-tags"></i> <span class="ms-2 d-none d-sm-inline">Products (View Only)</span>
                                    </a>
                                </li>
                            }
                            <li class="nav-item w-100">
                                <a asp-controller="BoMs" asp-action="Index" class="nav-link text-white px-0 align-middle">
                                    <i class="fs-5 bi-diagram-3"></i> <span class="ms-2 d-none d-sm-inline">Bills of Materials</span>
                                </a>
                            </li>

                            <li class="nav-item w-100 mt-2">
                                <span class="text-secondary small fw-bold text-uppercase d-none d-sm-inline">Engineering</span>
                            </li>
                            <li class="nav-item w-100">
                                <a asp-controller="ECOs" asp-action="Index" class="nav-link text-white px-0 align-middle">
                                    <i class="fs-5 bi-file-earmark-diff"></i> <span class="ms-2 d-none d-sm-inline">ECOs</span>
                                </a>
                            </li>

                            <li class="nav-item w-100 mt-2">
                                <span class="text-secondary small fw-bold text-uppercase d-none d-sm-inline">Analysis</span>
                            </li>
                            <li class="nav-item w-100">
                                <a asp-controller="Reports" asp-action="Index" class="nav-link text-white px-0 align-middle">
                                    <i class="fs-5 bi-bar-chart"></i> <span class="ms-2 d-none d-sm-inline">Reports</span>
                                </a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item w-100 mt-2">
                                    <span class="text-secondary small fw-bold text-uppercase d-none d-sm-inline">Configuration</span>
                                </li>
                                <li class="nav-item w-100">
                                    <a href="#" class="nav-link text-white px-0 align-middle">
                                        <i class="fs-5 bi-gear"></i> <span class="ms-2 d-none d-sm-inline">Settings</span>
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <hr class="w-100 text-white">
                    <div class="dropdown pb-4 w-100">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
            <div class="col py-3 px-4 main-content">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
