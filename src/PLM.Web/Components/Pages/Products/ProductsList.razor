@page "/products"
@using Microsoft.AspNetCore.Authorization
@using PLM.Application.DTOs
@using PLM.Application.Interfaces
@inject IProductService ProductService
@inject NavigationManager NavManager
@attribute [Authorize]

<PageTitle>Products - PLM Engineer</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4">Product Catalog</MudText>
        <AuthorizeView Roles="Engineering,Admin">
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/products/create">
                    Create Direct
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.History" Href="/eco/create?type=Product">
                    New via ECO
                </MudButton>
            </div>
        </AuthorizeView>
    </div>

    <MudDataGrid T="ProductDto" Items="@_products" Filterable="true" SortMode="SortMode.Multiple" Groupable="true" 
                 Hover="true" Dense="true" Elevation="2" Class="rounded-lg">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search products..." Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" 
                          OnKeyUp="HandleSearch" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" Filterable="true" />
            <PropertyColumn Property="x => x.Name" Title="Product Name" Sortable="true" Filterable="true" />
            <PropertyColumn Property="x => x.Description" Title="Description" Sortable="false" Filterable="false" />
            <PropertyColumn Property="x => x.CurrentVersionNumber" Title="Version" Sortable="true" />
            <TemplateColumn Title="Status">
                <CellTemplate>
                    @if (context.Item.Status == PLM.Domain.Enums.Status.Active)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">Active</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">Archived</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions">
                <CellTemplate>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" 
                               OnClick="@(() => ViewDetails(context.Item.Id))">View Details</MudButton>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="ProductDto" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<ProductDto> _products = new();
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        var result = await ProductService.GetPagedAsync(1, 100, _searchString);
        _products = result.Items.ToList();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadDataAsync();
        }
    }

    private void ViewDetails(int id)
    {
        NavManager.NavigateTo($"/products/{id}");
    }
}
