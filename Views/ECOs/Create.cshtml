@model PLM.Models.ECO

@{
    ViewData["Title"] = "Create ECO";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
<!-- Mockup Status Bar -->
<div class="card mb-4 border-0 shadow-sm border-bottom border-primary">
    <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center bg-white">
        <div class="d-flex align-items-center">
            <span class="btn btn-outline-secondary border-secondary px-4 fw-bold text-dark me-3" style="border-radius:0;">New</span>
            <span class="text-secondary fw-bold">PLM Overview / Engineering Change Orders</span>
        </div>
        <div>
            <!-- Fake Breadcrumbs/Status -->
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-primary fw-bold" style="clip-path: polygon(0% 0%, 90% 0%, 100% 50%, 90% 100%, 0% 100%, 10% 50%); padding-right: 30px; padding-left: 20px;">New</button>
                <button type="button" class="btn btn-light text-secondary disabled fw-bold" style="clip-path: polygon(0% 0%, 90% 0%, 100% 50%, 90% 100%, 0% 100%, 10% 50%); padding-right: 30px; padding-left: 30px; margin-left:-10px; z-index:0;">In Progress</button>
                <button type="button" class="btn btn-light text-secondary disabled fw-bold" style="clip-path: polygon(0% 0%, 90% 0%, 100% 50%, 90% 100%, 0% 100%, 10% 50%); padding-right: 30px; padding-left: 30px; margin-left:-10px; z-index:0;">Validated</button>
                <button type="button" class="btn btn-light text-secondary disabled fw-bold" style="clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%, 10% 50%); padding-right: 20px; padding-left: 30px; margin-left:-10px; z-index:0;">Effective</button>
            </div>
        </div>
    </div>
</div>

<form asp-action="Create" class="card shadow-sm border-0 p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <!-- Top Description Section -->
    <div class="mb-4">
        <label asp-for="Title" class="form-label text-muted fw-bold d-block">Description</label>
        <input asp-for="Title" class="form-control form-control-lg border-0 border-bottom border-secondary rounded-0 fs-3 fw-bold ps-0 mb-1" placeholder="e.g. ECO0004: Fix drawer assembly" />
        <span asp-validation-for="Title" class="text-danger small"></span>
    </div>

    <!-- Two Column Layout -->
    <div class="row gx-5">
        <!-- Left Column -->
        <div class="col-md-6 border-end">
            <!-- Type (Fake readonly to match mockup) -->
            <div class="row align-items-center mb-3">
                <div class="col-sm-4 text-muted fw-bold">Type</div>
                <div class="col-sm-8 text-secondary">Product Improvement</div>
            </div>

            <!-- Apply On (Radios governing ECOType) -->
            <div class="row align-items-start mb-3">
                <div class="col-sm-4 text-muted fw-bold">Apply on</div>
                <div class="col-sm-8">
                    <div class="form-check text-primary fw-bold mb-2">
                        <input class="form-check-input" type="radio" asp-for="Type" value="1" id="typeBom" checked>
                        <label class="form-check-label" for="typeBom">Bill of Materials</label>
                    </div>
                    <div class="form-check text-secondary">
                        <input class="form-check-input" type="radio" asp-for="Type" value="0" id="typeProd">
                        <label class="form-check-label" for="typeProd">Product Only</label>
                    </div>
                </div>
            </div>

            <div class="row align-items-center mb-3">
                <div class="col-sm-4 text-muted fw-bold">Product</div>
                <div class="col-sm-8">
                    <select asp-for="ProductId" class="form-select border-0 text-primary fw-bold" asp-items="ViewBag.Products">
                        <option value="">-- Select Product --</option>
                    </select>
                    <span asp-validation-for="ProductId" class="text-danger small"></span>
                </div>
            </div>

            <div class="row align-items-center mb-3">
                <div class="col-sm-4 text-muted fw-bold">Bill of Materials</div>
                <div class="col-sm-8">
                    <input type="number" asp-for="BoMId" class="form-control border-0 text-primary fw-bold" placeholder="Optional BoM ID or Auto-Populate..." />
                    <span asp-validation-for="BoMId" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-md-6 ps-4">
            <div class="row align-items-center mb-3">
                <div class="col-sm-4 text-muted fw-bold">Responsible</div>
                <div class="col-sm-8 text-secondary">@User.Identity?.Name</div>
            </div>

            <div class="row align-items-start mb-3">
                <div class="col-sm-4 text-muted fw-bold">Effective <i class="bi-question-circle text-info ms-1"></i></div>
                <div class="col-sm-8">
                    <div class="form-check text-primary fw-bold mb-2">
                        <input class="form-check-input" type="radio" name="EffectiveType" id="effAsap" value="ASAP" checked>
                        <label class="form-check-label" for="effAsap">As soon as possible</label>
                    </div>
                    <div class="form-check text-secondary">
                        <input class="form-check-input" type="radio" name="EffectiveType" id="effDate" value="Date">
                        <label class="form-check-label" for="effDate">At Date</label>
                    </div>
                </div>
            </div>

            <div class="row align-items-center mb-3">
                <div class="col-sm-4 text-muted fw-bold">Tags</div>
                <div class="col-sm-8">
                    <input type="text" class="form-control border-0" placeholder="e.g. Improvement" />
                </div>
            </div>

            <div class="row align-items-center mb-3">
                <div class="col-sm-4 text-muted fw-bold">Update Version <i class="bi-question-circle text-info ms-1"></i></div>
                <div class="col-sm-8">
                    <div class="form-check">
                        <input asp-for="IsVersionUpdate" class="form-check-input bg-primary border-primary" style="transform: scale(1.3)" type="checkbox" checked />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Actions -->
    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-primary px-4 shadow-sm">Start Revision (Save)</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Discard</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
