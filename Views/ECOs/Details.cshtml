@model PLM.Controllers.ECOViewModel

@{
    ViewData["Title"] = "ECO Details - " + Model.ReferenceNumber;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">ECO Details: <span class="fw-bold text-primary">@Model.ReferenceNumber</span></h1>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="bi-arrow-left me-1"></i> Back to List</a>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Overview Card -->
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 font-weight-bold text-primary">Overview</h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Title</dt>
                    <dd class="col-sm-9 fw-bold">@Model.Title</dd>

                    <dt class="col-sm-3 text-muted">ECO Type</dt>
                    <dd class="col-sm-9"><span class="badge bg-secondary">@Model.Type</span></dd>

                    <dt class="col-sm-3 text-muted">Target Product</dt>
                    <dd class="col-sm-9">@Model.ProductName</dd>

                    <dt class="col-sm-3 text-muted">Version Update</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsVersionUpdate) { <span class="badge bg-success">Yes - Creates New Version</span> }
                        else { <span class="badge bg-warning text-dark">No - Overwrites Current</span> }
                    </dd>
                </dl>
            </div>
        </div>

        <!-- Proposed Changes Section -->
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between border-bottom border-dark">
                <h6 class="m-0 font-weight-bold text-primary"><i class="bi-file-diff me-2"></i>Proposed Changes (Diff)</h6>
                @if (Model.Stage == PLM.Models.ECOStage.New && (User.IsInRole("Admin") || User.IsInRole("Engineering User")))
                {
                    <a asp-action="EditDraft" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary"><i class="bi-pencil me-1"></i> Edit Draft</a>
                }
            </div>
            <div class="card-body p-0">
                @if (Model.ParsedChanges.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi-file-earmark-code fs-1 d-block mb-3 opacity-50"></i>
                        No changes proposed yet.
                    </div>
                }
                else if (Model.Type == PLM.Models.ECOType.Product && Model.OldProduct != null)
                {
                    <table class="table diff-table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 30%">Property</th>
                                <th style="width: 35%">Current (Active) Value</th>
                                <th style="width: 35%">Proposed Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ParsedChanges.ContainsKey("SalePrice"))
                            {
                                var oldVal = Model.OldProduct.SalePrice;
                                var newVal = Convert.ToDecimal(Model.ParsedChanges["SalePrice"]);
                                <tr>
                                    <td class="fw-bold">Sale Price</td>
                                    <td><span class="old-val">₹ @oldVal.ToString("N2")</span></td>
                                    <td>
                                        <span class="new-val @(newVal > oldVal ? "text-success" : (newVal < oldVal ? "text-danger" : ""))">
                                            ₹ @newVal.ToString("N2")
                                            @if(newVal > oldVal) { <i class="bi-arrow-up-short"></i> } else if (newVal < oldVal) { <i class="bi-arrow-down-short"></i> }
                                        </span>
                                    </td>
                                </tr>
                            }
                            @if (Model.ParsedChanges.ContainsKey("CostPrice"))
                            {
                                var oldVal = Model.OldProduct.CostPrice;
                                var newVal = Convert.ToDecimal(Model.ParsedChanges["CostPrice"]);
                                <tr>
                                    <td class="fw-bold">Cost Price</td>
                                    <td><span class="old-val">₹ @oldVal.ToString("N2")</span></td>
                                    <td>
                                        <span class="new-val @(newVal > oldVal ? "text-danger" : (newVal < oldVal ? "text-success" : ""))">
                                            ₹ @newVal.ToString("N2")
                                            @if(newVal > oldVal) { <i class="bi-arrow-up-short"></i> } else if (newVal < oldVal) { <i class="bi-arrow-down-short"></i> }
                                        </span>
                                    </td>
                                </tr>
                            }
                            @if (Model.ParsedChanges.ContainsKey("Name"))
                            {
                                var oldVal = Model.OldProduct.Name;
                                var newVal = Model.ParsedChanges["Name"];
                                <tr>
                                    <td class="fw-bold">Product Name</td>
                                    <td><span class="old-val">@oldVal</span></td>
                                    <td><span class="new-val text-info">@newVal</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (Model.Type == PLM.Models.ECOType.BoM && Model.OldBoM != null)
                {
                    var bomDiff = System.Text.Json.JsonSerializer.Deserialize<PLM.Controllers.BoMDiffDTO>(Model.ProposedChangesJson, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    <div class="px-3 pt-3">
                        <strong class="text-secondary"><i class="bi-box me-2"></i>Components</strong>
                        <table class="table table-sm mt-2">
                            <thead><tr><th>Component ID</th><th>Current Qty</th><th>Proposed Qty</th></tr></thead>
                            <tbody>
                                @foreach (var comp in bomDiff?.Components ?? new List<PLM.Controllers.BoMComponentDiff>())
                                {
                                    var oldComp = Model.OldBoM.Components.FirstOrDefault(c => c.ProductId == comp.ProductId);
                                    var oldQty = oldComp?.Quantity ?? 0;
                                    <tr>
                                        <td>Product #@comp.ProductId</td>
                                        <td><span class="@(oldQty > 0 && oldQty != comp.Quantity ? "old-val" : "")">@oldQty</span></td>
                                        <td>
                                            <span class="new-val @(comp.Quantity > oldQty ? "text-success" : (comp.Quantity < oldQty ? "text-danger" : ""))">
                                                @comp.Quantity
                                                @if(comp.Quantity > oldQty) { <i class="bi-arrow-up-short"></i> } else if (comp.Quantity < oldQty) { <i class="bi-arrow-down-short"></i> }
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <hr />
                        <strong class="text-secondary"><i class="bi-gear me-2"></i>Operations</strong>
                        <table class="table table-sm mt-2">
                            <thead><tr><th>Operation Target</th><th>Current Time (m)</th><th>Proposed Time (m)</th></tr></thead>
                            <tbody>
                                @foreach (var op in bomDiff?.Operations ?? new List<PLM.Controllers.BoMOperationDiff>())
                                {
                                    var oldOp = Model.OldBoM.Operations.FirstOrDefault(o => o.Name == op.Name);
                                    var oldTime = oldOp?.TimeMinutes ?? 0;
                                    <tr>
                                        <td>@op.Name</td>
                                        <td><span class="@(oldTime > 0 && oldTime != op.TimeMinutes ? "old-val" : "")">@oldTime</span></td>
                                        <td>
                                            <span class="new-val @(op.TimeMinutes > oldTime ? "text-danger" : (op.TimeMinutes < oldTime ? "text-success" : ""))">
                                                @op.TimeMinutes
                                                @if(op.TimeMinutes > oldTime) { <i class="bi-arrow-up-short"></i> } else if (op.TimeMinutes < oldTime) { <i class="bi-arrow-down-short"></i> }
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-3">
                        <pre class="bg-light text-dark p-3 border rounded mb-0"><code>@Model.ProposedChangesJson</code></pre>
                    </div>
                }
            </div>
        </div>
        
        <!-- Audit Logs -->
        <div class="card shadow border-0">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 font-weight-bold text-primary">ECO Logs & History</h6>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var log in Model.Logs)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <span class="fw-bold">@log.Action</span>
                                <span class="text-muted ms-2 small">by @log.UserId</span>
                                @if (!string.IsNullOrEmpty(log.Comments))
                                {
                                    <div class="small text-muted mt-1"><i class="bi-chat-left-text me-1"></i> @log.Comments</div>
                                }
                            </div>
                            <span class="badge bg-light text-dark">@log.Timestamp.ToString("g")</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <!-- Lifecycle Card -->
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 font-weight-bold text-primary">Lifecycle & Routing</h6>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <span class="text-muted d-block mb-1 small fw-bold text-uppercase">Current Stage</span>
                    @if (Model.Stage == PLM.Models.ECOStage.New)
                    {
                        <span class="badge bg-info py-2 w-100 fs-6">Draft (New)</span>
                    }
                    else if (Model.Stage == PLM.Models.ECOStage.Approval)
                    {
                        <span class="badge bg-warning text-dark py-2 w-100 fs-6">In Review</span>
                    }
                    else
                    {
                        <span class="badge bg-success py-2 w-100 fs-6"><i class="bi-check-circle me-1"></i> Applied</span>
                    }
                </div>

                @if (Model.Stage == PLM.Models.ECOStage.New && !User.IsInRole("Operations User"))
                {
                    <form asp-action="SubmitForApproval" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-primary w-100"><i class="bi-send me-1"></i> Submit for Approval</button>
                    </form>
                }
                else if (Model.Stage == PLM.Models.ECOStage.Approval && (User.IsInRole("Admin") || User.IsInRole("Approver")))
                {
                    <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="mb-2">
                        <button type="submit" class="btn btn-success w-100"><i class="bi-check-lg me-1"></i> Approve & Proceed</button>
                    </form>
                    <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-outline-danger w-100"><i class="bi-x-lg me-1"></i> Reject back to Draft</button>
                    </form>
                }
                else if (Model.Stage == PLM.Models.ECOStage.Approval && !User.IsInRole("Approver") && !User.IsInRole("Admin"))
                {
                    <div class="alert alert-warning small mb-0">
                        <i class="bi-hourglass me-1"></i> Waiting for an Approver.
                    </div>
                }
                else if (Model.Stage == PLM.Models.ECOStage.Done)
                {
                    <div class="alert alert-success small mb-0">
                        <i class="bi-check-circle me-1"></i> Changes have been fully merged and recorded.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
