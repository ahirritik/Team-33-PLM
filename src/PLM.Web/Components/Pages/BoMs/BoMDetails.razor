@page "/boms/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using PLM.Application.DTOs
@using PLM.Application.Interfaces
@inject IBoMService BoMService
@inject NavigationManager NavManager
@attribute [Authorize]

<PageTitle>BoM Details - PLM Engineer</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_bom == null && _isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (_bom == null)
    {
        <MudAlert Severity="Severity.Error">Bill of Material not found.</MudAlert>
    }
    else
    {
        <MudGrid>
            <!-- BoM Information Header -->
            <MudItem xs="12">
                <MudPaper Elevation="3" Class="pa-6 rounded-lg d-flex justify-space-between align-center mud-theme-primary">
                    <div>
                        <MudText Typo="Typo.h5" Class="text-white">@_bom.Name</MudText>
                        <MudText Typo="Typo.body2" Class="text-white py-1">ID: BOM-@_bom.Id.ToString("D5") | Product: <a href="/products/@_bom.ProductId" class="text-white text-decoration-underline">@_bom.ProductName</a></MudText>
                        <div class="d-flex align-center mt-2">
                            <MudChip T="string" Color="Color.Surface" Size="Size.Small" Class="mr-2 text-primary font-weight-bold">v@_bom.CurrentVersionNumber</MudChip>
                            @if (_bom.Status == PLM.Domain.Enums.Status.Active)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Active</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">Archived</MudChip>
                            }
                        </div>
                    </div>
                    <div>
                        <AuthorizeView Roles="Engineering,Admin">
                            <MudButton Variant="Variant.Filled" Color="Color.Surface" Class="text-primary font-weight-bold" StartIcon="@Icons.Material.Filled.Edit" 
                                       Href="@($"/eco/create?type=BoM&bomId={_bom.Id}&productId={_bom.ProductId}")">
                                Modify via ECO
                            </MudButton>
                        </AuthorizeView>
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Active Version Details -->
            @if (_bom.ActiveVersion != null)
            {
                <MudItem xs="12" md="12">
                    <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                        <MudText Typo="Typo.h6" Class="mb-4">Active Version (v@_bom.ActiveVersion.VersionNumber) Details</MudText>
                        
                        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="false">
                            <MudTabPanel Text="Components" Icon="@Icons.Material.Filled.Build">
                                <MudDataGrid T="BoMComponentDto" Items="@_bom.ActiveVersion.Components" Dense="true" Hover="true" Class="mt-4">
                                    <Columns>
                                        <PropertyColumn Property="x => x.PartNumber" Title="Part #" />
                                        <PropertyColumn Property="x => x.ComponentName" Title="Component" />
                                        <PropertyColumn Property="x => x.Quantity" Title="Qty" />
                                        <PropertyColumn Property="x => x.Unit" Title="Unit" />
                                        <PropertyColumn Property="x => x.UnitCost" Title="Unit Cost">
                                            <CellTemplate>@context.Item.UnitCost.ToString("C")</CellTemplate>
                                        </PropertyColumn>
                                        <TemplateColumn Title="Total Cost">
                                            <CellTemplate>@((context.Item.UnitCost * context.Item.Quantity).ToString("C"))</CellTemplate>
                                        </TemplateColumn>
                                    </Columns>
                                </MudDataGrid>
                                
                                <div class="d-flex justify-end mt-4 px-4 py-2 bg-light rounded">
                                    <MudText Typo="Typo.h6">Total Material Cost: <span class="text-primary">@_bom.ActiveVersion.TotalCost.ToString("C")</span></MudText>
                                </div>
                            </MudTabPanel>
                            
                            <MudTabPanel Text="Operations (Routing)" Icon="@Icons.Material.Filled.Route">
                                <MudDataGrid T="BoMOperationDto" Items="@_bom.ActiveVersion.Operations.OrderBy(o => o.SequenceOrder)" Dense="true" Hover="true" Class="mt-4">
                                    <Columns>
                                        <PropertyColumn Property="x => x.SequenceOrder" Title="Seq" />
                                        <PropertyColumn Property="x => x.OperationName" Title="Operation" />
                                        <PropertyColumn Property="x => x.Description" Title="Description" />
                                        <PropertyColumn Property="x => x.EstimatedTime" Title="Est. Time (min)" />
                                        <PropertyColumn Property="x => x.WorkCenter" Title="Work Center" />
                                    </Columns>
                                </MudDataGrid>
                                
                                <div class="d-flex justify-end mt-4 px-4 py-2 bg-light rounded">
                                    <MudText Typo="Typo.h6">Total Est. Time: <span class="text-primary">@_bom.ActiveVersion.Operations.Sum(o => o.EstimatedTime) min</span></MudText>
                                </div>
                            </MudTabPanel>
                        </MudTabs>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private BoMDto? _bom;
    private bool _isLoading = true;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs.Add(new BreadcrumbItem("Dashboard", href: "/"));
        _breadcrumbs.Add(new BreadcrumbItem("Bills of Material", href: "/boms"));
        
        await LoadBoMAsync();
    }

    private async Task LoadBoMAsync()
    {
        _isLoading = true;
        
        // IBoMService.GetByIdAsync returns BoMDto with its ActiveVersion populated.
        _bom = await BoMService.GetByIdAsync(Id);
        
        if (_bom != null)
        {
            _breadcrumbs.Add(new BreadcrumbItem(_bom.Name, href: null, disabled: true));
        }
        
        _isLoading = false;
    }
}
