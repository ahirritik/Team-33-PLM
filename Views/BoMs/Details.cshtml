@model PLM.Controllers.BoMViewModel

@{
    ViewData["Title"] = "BoM Details - " + Model.ProductName;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">BoM Details: @Model.ProductName <span class="badge bg-secondary ms-2 align-middle">@Model.Version</span></h1>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="bi-arrow-left me-1"></i> Back to List</a>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Components Card -->
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Components</h6>
                @if (Model.Status == PLM.Models.BoMStatus.Active && (User.IsInRole("Admin") || User.IsInRole("Engineering User")))
                {
                    <button class="btn btn-sm btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#addComponentForm"><i class="bi-plus"></i> Add</button>
                }
            </div>
            <div class="card-body">
                <!-- Inline Add Component Form -->
                <div class="collapse mb-3" id="addComponentForm">
                    <div class="card card-body bg-light border">
                        <form asp-controller="BoMs" asp-action="AddComponent" method="post">
                            <input type="hidden" name="BoMId" value="@Model.Id" />
                            <div class="row g-2 align-items-end">
                                <div class="col-md-5">
                                    <label class="form-label small fw-bold">Component Product ID</label>
                                    <input type="number" name="ProductId" class="form-control" placeholder="Product ID" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Quantity</label>
                                    <input type="number" name="Quantity" step="0.01" class="form-control" placeholder="Qty" required />
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-success w-100"><i class="bi-check"></i> Save</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Component Product</th>
                            <th>Quantity</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var c in Model.ComponentsList)
                        {
                            <tr>
                                <td>@c.ProductName</td>
                                <td>@c.Quantity</td>
                                <td>
                                    <form asp-controller="BoMs" asp-action="RemoveComponent" method="post" style="display:inline;">
                                        <input type="hidden" name="componentId" value="@c.Id" />
                                        <input type="hidden" name="bomId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if(!Model.ComponentsList.Any())
                        {
                            <tr><td colspan="3" class="text-muted">No components mapped.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Operations Card -->
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Operations (Routing)</h6>
                @if (Model.Status == PLM.Models.BoMStatus.Active && (User.IsInRole("Admin") || User.IsInRole("Engineering User")))
                {
                    <button class="btn btn-sm btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#addOperationForm"><i class="bi-plus"></i> Add</button>
                }
            </div>
            <div class="card-body">
                <!-- Inline Add Operation Form -->
                <div class="collapse mb-3" id="addOperationForm">
                    <div class="card card-body bg-light border">
                        <form asp-controller="BoMs" asp-action="AddOperation" method="post">
                            <input type="hidden" name="BoMId" value="@Model.Id" />
                            <div class="row g-2 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold">Operation Name</label>
                                    <input type="text" name="Name" class="form-control" placeholder="e.g. Assembly" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold">Work Center</label>
                                    <input type="text" name="WorkCenter" class="form-control" placeholder="e.g. Line A" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold">Time (Minutes)</label>
                                    <input type="number" name="TimeMinutes" class="form-control" placeholder="30" required />
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-success w-100"><i class="bi-check"></i> Save</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Operation</th>
                            <th>Work Center</th>
                            <th>Time (Mins)</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var op in Model.OperationsList)
                        {
                            <tr>
                                <td>@op.Name</td>
                                <td>@op.WorkCenter</td>
                                <td>@op.TimeMinutes</td>
                                <td>
                                    <form asp-controller="BoMs" asp-action="RemoveOperation" method="post" style="display:inline;">
                                        <input type="hidden" name="operationId" value="@op.Id" />
                                        <input type="hidden" name="bomId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if(!Model.OperationsList.Any())
                        {
                            <tr><td colspan="4" class="text-muted">No operations mapped.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <!-- Info Card -->
        <div class="card shadow mb-4 border-0">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 font-weight-bold text-primary">Status & Configuration</h6>
            </div>
            <div class="card-body">
                @if (Model.Status == PLM.Models.BoMStatus.Active)
                {
                    <span class="badge bg-success mb-3 w-100 py-2 fs-6">Active BoM</span>
                    
                    if (User.IsInRole("Admin") || User.IsInRole("Engineering User"))
                    {
                        <hr />
                        <p class="text-muted small">To safely version and change this BoM for manufacturing, raise an ECO.</p>
                        <a asp-controller="ECOs" asp-action="Create" asp-route-productId="@Model.ProductId" asp-route-type="1" class="btn btn-warning w-100"><i class="bi-file-earmark-diff"></i> Raise BoM ECO</a>
                    }
                }
                else
                {
                    <span class="badge bg-dark mb-3 w-100 py-2 fs-6">Archived BoM</span>
                    <div class="alert alert-secondary mb-0">
                        <i class="bi-info-circle me-1"></i> Archived BoM cannot be used in active ECOs or operations.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
